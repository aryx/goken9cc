# Minimal hello world like programs in assembly for many architectures
# and also many OSes!
# Good to test the very basic features of a toolchain (assembler and linker).
# You can add -v to some linker command to help debug.

LINUXBINS=hello_linux_386.exe hello_linux_amd64.exe \
          hello_linux_arm.exe hello_linux_arm64.exe \
          hello_linux_mips.exe hello_linux_riscv.exe hello_linux_riscv64.exe \
                 hello_linux_386_.exe hello_linux_arm_.exe hello_linux_amd64_.exe
MACOSBINS=hello_macos_amd64.exe hello_macos_arm64.exe \
          hello_macos_libc_amd64.exe
WINDOWSBINS=hello_windows_386.exe hello_windows_amd64.exe
PLAN9BINS=hello_plan9_386.exe hello_plan9_arm.exe hello_plan9_mips.exe
#TODO: hello_xv6_386.exe hello_xv6_riscv.exe and possibly hello_xv6_arm.exe
XV6BINS=

all:V: $LINUXBINS $MACOSBINS $WINDOWSBINS $PLAN9BINS $XV6BINS

# This target is part of mk test CI regression check in Dockerfile and GHA
# (it requires just qemu-user; see ../../../scripts/qemu-runner for why we
# no longer rely on qemu-user-binfmt / binfmt_misc, which used to need
# forcing for mips since it picked qemu-mips32sn instead of qemu-mips).
# Windows PE binaries are checked the same way, but under wine instead of
# qemu-user: wine translates the Win32/kernel32.dll ABI in userspace, no
# per-arch emulator binary needed (see the Dockerfile's `test` stage).
# Unlike qemu-user, wine does not translate the CPU ISA, only the Win32
# ABI, so it can only run these (x86/amd64) PE binaries natively on an
# x86_64 host; skip on arm64 hosts, same spirit as the arm64/Darwin
# codesign guard down in the hello_macos_arm64.exe recipe below.
# (the exit(42) programs moved to tests/s/exit, which asserts their code)
# Every hello prints exactly "Hello, world\n"; cmp against hello.expected.txt
# so a silently-wrong program (e.g. writing nothing, or a bad byte) fails the
# test instead of passing on a bare "it ran" -- like tests/c/mini does.
test:V: all
      for (i in $LINUXBINS) {
         echo $i
         arch=`{echo $i | sed 's/^hello_linux_//; s/\.exe$//'}
         ../../../scripts/qemu-runner $arch ./$i | cmp /dev/stdin hello.expected.txt
      }
      if(~ `{uname -m} x86_64) for (i in $WINDOWSBINS) {
         echo $i
         WINEDEBUG=-all wine ./$i | cmp /dev/stdin hello.expected.txt
      }
      if not
         echo 'skipping Windows/wine tests: wine only runs x86 PE natively on an x86_64 host'

clean:V:
	rm -f *.[5678ivj] *.exe

#Linux
# old: -X to avoid the golang specific stuff and -d to disable dynamic linking
hello_linux_386.exe: hello_linux_386.s
   8a -c $prereq
   8l -H7 -o $target -E _start hello_linux_386.8
hello_linux_386_.exe: hello_linux_386_.s
   8ag -c $prereq
   8lg -o $target -E _start hello_linux_386_.8
hello_linux_amd64.exe: hello_linux_amd64.s
   6a -c $prereq
   6l -H7 -o $target -E _start hello_linux_amd64.6
hello_linux_amd64_.exe: hello_linux_amd64_.s
   6ag -c $prereq
   6lg -o $target -E _start hello_linux_amd64_.6
hello_linux_arm.exe: hello_linux_arm.s
   5a -c $prereq
   5l -H7 -o $target -E _start hello_linux_arm.5
hello_linux_arm_.exe: hello_linux_arm_.s
   5ag -c $prereq
   5lg -o $target -E _start hello_linux_arm_.5
hello_linux_arm64.exe: hello_linux_arm64.s
   7a -c $prereq
   7l -H7 -o $target -E _start hello_linux_arm64.7
hello_linux_riscv.exe: hello_linux_riscv.s
   ia -c $prereq
   il -o $target -E _start hello_linux_riscv.i
hello_linux_riscv64.exe: hello_linux_riscv64.s
   ja -c $prereq
   jl -o $target -E _start hello_linux_riscv64.j
hello_linux_mips.exe: hello_linux_mips.s
   va -c $prereq
   vl -o $target -E _start hello_linux_mips.v
			

# macOS
# -H6 selects the apple MACH (Mach-O) header. 6l (linkers/lk/macho.c)
# emits the modern format: LC_MAIN entry (not LC_UNIXTHREAD),
# MH_DYLDLINK|MH_TWOLEVEL|MH_PIE, links /usr/lib/libSystem.B.dylib, and
# carries LC_DYLD_INFO_ONLY and LC_BUILD_VERSION. (-s is redundant here
# -- 6l always strips for -H6, no symbol-table path exists yet -- but
# kept for clarity/parity with the other -H6 recipes below.)
hello_macos_amd64.exe: hello_macos_amd64.s
   6a -c $prereq
   6l -s -H6 -o $target -E _start hello_macos_amd64.6

# the codesign step is mandatory on arm64 macOS: the kernel SIGKILLs
# unsigned (or non-PIE, or static) arm64 executables at exec() time.
# It is skipped when cross-building from Linux (CI), where the binary
# can not run anyway. See docs/notes_macos.txt for the whole story.
hello_macos_arm64.exe: hello_macos_arm64.s
   7a -c $prereq
   7l -H6 -o $target -E _start hello_macos_arm64.7
   if(~ `{uname} Darwin) codesign -s - -f $target
   if not true

# Same as hello_macos_amd64 but calls libSystem's _write instead of a raw
# syscall: -I declares the import, 6lg binds it (LC_DYLD_INFO) into the writep
# GOT slot. This is the variant that actually runs under darling (which
# emulates Darwin via libSystem and does not translate raw syscalls).
# Still 6ag/6lg (Go-era): linkers/lk/macho.c has no -I/dynamic-import
# support yet, unlike the kernel32.dll imports lk/pe.c already does for
# -H10 -- a Mach-O counterpart would be the natural next step.
hello_macos_libc_amd64.exe: hello_macos_libc_amd64.s
   6ag -c $prereq
   6lg -s -H6 -I writep:_write:/usr/lib/libSystem.B.dylib -o $target -E _start hello_macos_libc_amd64.6

# Plan9
# -H 2 this time and -E _main
hello_plan9_386.exe: hello_plan9_386.s
   8ag -c $prereq
   8lg -o $target -H 2 -E _main hello_plan9_386.8
hello_plan9_arm.exe: hello_plan9_arm.s
   5ag -c $prereq
   5lg -o $target -H 2 -E _main hello_plan9_arm.5
# actually no need -X; va/vc/vl are new and were not "go-ized"
# actually -X would print the assembly on stdout in vl ...
hello_plan9_mips.exe: hello_plan9_mips.s
   va -c $prereq
   vl -o $target -H 2 -E _main hello_plan9_mips.v

# Windows (PE). Both link a kernel32.dll .idata (GetStdHandle, WriteFile,
# ExitProcess) and expose the thunks as __imp_* symbols so the program can
# print. See linkers/lk/pe.c. -s because there is no PE symbol table path
# yet. Run under wine on Linux hosts; the `test` target above does this
# for both automatically as part of `mk test`.
#
# 386 uses 8lg (goken/src-cmd lineage): the principia 8l in linkers/8l/
# does not have -H 10 wired. amd64 uses 6l -H 10 (linkers/lk/pe.c),
# which emits a PE32+ (64-bit) optional header.
hello_windows_386.exe: hello_windows_386.s
   8ag $prereq
   8lg -s -H 10 -o $target -E _start hello_windows_386.8
hello_windows_amd64.exe: hello_windows_amd64.s
   6a -c $prereq
   6l -s -H 10 -o $target -E _start hello_windows_amd64.6

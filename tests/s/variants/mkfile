# Cross-check the two toolchain lineages on toy inputs:
#  - the kencc lineage (8a/8c/8l, 5a/5c/5l, from assemblers/8ak etc.),
#    known good, able to cross-compile principia
#  - the principia-synced lineage (8a___/8c___/8l___, ..., from
#    assemblers/8a etc.), kept in sync with the principia books via syncweb
# The goal of the merge work is that both lineages produce byte-identical
# object files and executables.
#
# Requirements for byte-comparable (and committable) outputs:
#  - the assemblers' -r flag (reproducible: don't embed the cwd in the
#    object file history records)
#  - the linkers' -s flag (strip the symbol table, which would otherwise
#    also embed source paths in the executable)
#
# expected/ holds golden reference outputs produced by the kencc lineage
# (see the 'golden' target to regenerate them). They protect against both
# lineages drifting together. The C compilers are compared separately
# in tests/c/variants.

# float_386 and const_386 exercise historically long->int32 sensitive
# paths (ieee float encoding, large/negative constants), see changes.txt.
TESTS386=hello_386 float_386 const_386 macro_386
TESTSARM=hello_arm

test:V: test386 testgolden

# byte-compare object files and executables produced by the two lineages
test386:V: ${TESTS386:%=%.vcmp8}
	./hello_386.k.exe

# Not yet in the default 'test' target: the arm lineages do not agree yet
# (include/5.out.h and linkers/5lk/5.out.h differ in opcode numbering and
# operand encoding). Enable once 5.out.h is reconciled.
testarm:V: ${TESTSARM:%=%.vcmp5}
	./hello_arm.k.exe

# Regression check: the kencc lineage still produces the committed
# reference outputs (the arm part guards kencc itself even though the
# two arm lineages do not agree yet).
testgolden:V: ${TESTS386:%=%.vgold8} ${TESTSARM:%=%.vgold5}

# compare stripped and -S executables: the symbol table is only emitted
# without -s, and the ELF section table only with -S; e.g. the
# elf32sectab() data offset bug was invisible in stripped links
%.vcmp8:V:
	8a    -r -c -o $stem.k.8 $stem.s
	8a___ -r -c -o $stem.p.8 $stem.s
	cmp $stem.k.8 $stem.p.8
	8l    -s -H7 -E _start -o $stem.k.exe $stem.k.8
	8l___ -s -H7 -E _start -o $stem.p.exe $stem.p.8
	cmp $stem.k.exe $stem.p.exe
	8l    -S -H7 -E _start -o $stem.ksym.exe $stem.k.8
	8l___ -S -H7 -E _start -o $stem.psym.exe $stem.p.8
	cmp $stem.ksym.exe $stem.psym.exe

%.vcmp5:V:
	5a    -r -c -o $stem.k.5 $stem.s
	5a___ -r -c -o $stem.p.5 $stem.s
	cmp $stem.k.5 $stem.p.5
	5l    -s -H7 -E _start -o $stem.k.exe $stem.k.5
	5l___ -s -H7 -E _start -o $stem.p.exe $stem.p.5
	cmp $stem.k.exe $stem.p.exe

# uses .g.* names because mk can run this in parallel with test386
%.vgold8:V:
	8a -r -c -o $stem.g.8 $stem.s
	cmp $stem.g.8 expected/$stem.8
	8l -s -H7 -E _start -o $stem.g.exe $stem.g.8
	cmp $stem.g.exe expected/$stem.exe
	8l -S -H7 -E _start -o $stem.gsym.exe $stem.g.8
	cmp $stem.gsym.exe expected/$stem.sym.exe

%.vgold5:V:
	5a -r -c -o $stem.g.5 $stem.s
	cmp $stem.g.5 expected/$stem.5
	5l -s -H7 -E _start -o $stem.g.exe $stem.g.5
	cmp $stem.g.exe expected/$stem.exe

# Regenerate the golden reference outputs from the kencc lineage.
# Only run this deliberately, after verifying the new outputs are correct
# (e.g. the executables still run).
golden:V: ${TESTS386:%=%.mkgold8} ${TESTSARM:%=%.mkgold5}

%.mkgold8:V:
	8a -r -c -o expected/$stem.8 $stem.s
	8l -s -H7 -E _start -o expected/$stem.exe expected/$stem.8
	8l -S -H7 -E _start -o expected/$stem.sym.exe expected/$stem.8

%.mkgold5:V:
	5a -r -c -o expected/$stem.5 $stem.s
	5l -s -H7 -E _start -o expected/$stem.exe expected/$stem.5

clean nuke:V:
	rm -f *.[58] *.exe

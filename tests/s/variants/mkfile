# Cross-check the two toolchain lineages on toy inputs:
#  - the kencc lineage (8ak/8ck/8lk, from assemblers/8ak etc.),
#    known good, the original reference
#  - the principia-synced lineage (8a/8c/8l, from assemblers/8a etc.),
#    kept in sync with the principia books via syncweb; now the default
#    install names since it was proven byte-identical to kencc over the
#    whole principia corpus (see tests/scripts/cmp-*-corpus.sh)
# Both arches are now swapped the same way: the principia-synced lineage
# installs under the plain names (8a/8c/8l, 5a/5c/5l) and the kencc lineage
# under the k names (8ak/8ck/8lk, 5ak/5ck/5lk). arm reached parity after
# the 5.out.h merge and the whole-corpus byte-identity proof (asm/compiler
# sweeps + cmp-exec-corpus-arm.sh: 254/254 including the 9pi kernel).
# The goal of the merge work is that both lineages produce byte-identical
# object files and executables.
#
# Requirements for byte-comparable (and committable) outputs:
#  - the assemblers' -r flag (reproducible: don't embed the cwd in the
#    object file history records)
#  - the linkers' -s flag (strip the symbol table, which would otherwise
#    also embed source paths in the executable)
#
# expected/ holds golden reference outputs produced by the kencc lineage
# (see the 'golden' target to regenerate them). They protect against both
# lineages drifting together. The C compilers are compared separately
# in tests/c/variants.

# float_386 and const_386 exercise historically long->int32 sensitive
# paths (ieee float encoding, large/negative constants), see changes.txt.
TESTS386=hello_386 float_386 const_386 macro_386
TESTSARM=hello_arm swi_line_arm addr_arm call_arm

test:V: test386 testarm testgolden

# byte-compare object files and executables produced by the two lineages
test386:V: ${TESTS386:%=%.vcmp8}
	../../../scripts/qemu-runner 386 ./hello_386.k.exe

# The arm lineages agree since the 5.out.h merge: both share
# include/5.out.h (principia numbering), with linkers/5lk/5.out.h a
# thin compat wrapper for the kencc-only identifiers.
testarm:V: ${TESTSARM:%=%.vcmp5} mixaddr_arm
	../../../scripts/qemu-runner arm ./hello_arm.k.exe

# mixaddr_arm: a symbol whose address is taken by BOTH the assembler
# ($shared(SB) -> D_ADDR) and the compiler (&shared -> D_CONST+name),
# linked together. The two must collapse to one literal-pool entry.
# principia's 5l canonicalizes D_CONST+name to D_ADDR in inopd(), so
# it deduped; kencc 5lk did not and kept two identical pool entries -- an
# 8-byte divergence that surfaced only in the kernel bootstrap link
# (init.out, which mixes init9.s + initcode.c and made the whole 9pi
# kernel differ). 5lk now applies the same canonicalization. -l -R1
# reproduces the bootstrap link mode. See linkers/5lk/obj.c zaddr /
# linkers/5lk/obj.c inopd.
mixaddr_arm:V:
	5ak    -r -c -o mixaddr_arm.s.k.5 mixaddr_arm.s
	5a -r -c -o mixaddr_arm.s.p.5 mixaddr_arm.s
	cmp mixaddr_arm.s.k.5 mixaddr_arm.s.p.5
	5ck    -r -o mixaddr_arm.c.5 mixaddr_arm.c
	5lk    -l -R1 -s -E _start -o mixaddr_arm.k.exe mixaddr_arm.s.k.5 mixaddr_arm.c.5
	5l -l -R1 -s -E _start -o mixaddr_arm.p.exe mixaddr_arm.s.k.5 mixaddr_arm.c.5
	cmp mixaddr_arm.k.exe mixaddr_arm.p.exe

# Regression check: the kencc lineage still produces the committed
# reference outputs.
testgolden:V: ${TESTS386:%=%.vgold8} ${TESTSARM:%=%.vgold5}

# compare stripped and -S executables: the symbol table is only emitted
# without -s, and the ELF section table only with -S; e.g. the
# elf32sectab() data offset bug was invisible in stripped links
%.vcmp8:V:
	8ak -r -c -o $stem.k.8 $stem.s
	8a  -r -c -o $stem.p.8 $stem.s
	cmp $stem.k.8 $stem.p.8
	8lk -s -H7 -E _start -o $stem.k.exe $stem.k.8
	8l  -s -H7 -E _start -o $stem.p.exe $stem.p.8
	cmp $stem.k.exe $stem.p.exe
	8lk -S -H7 -E _start -o $stem.ksym.exe $stem.k.8
	8l  -S -H7 -E _start -o $stem.psym.exe $stem.p.8
	cmp $stem.ksym.exe $stem.psym.exe

%.vcmp5:V:
	5ak    -r -c -o $stem.k.5 $stem.s
	5a -r -c -o $stem.p.5 $stem.s
	cmp $stem.k.5 $stem.p.5
	5lk    -s -H7 -E _start -o $stem.k.exe $stem.k.5
	5l -s -H7 -E _start -o $stem.p.exe $stem.p.5
	cmp $stem.k.exe $stem.p.exe
	# also compare UNSTRIPPED (the two lineages, same run -- no golden):
	# catches the addhist history-symbol-table mismatch (mallocz fix)
	# that the stripped compare above cannot see
	5lk    -H7 -E _start -o $stem.k.uexe $stem.k.5
	5l -H7 -E _start -o $stem.p.uexe $stem.p.5
	cmp $stem.k.uexe $stem.p.uexe

# uses .g.* names because mk can run this in parallel with test386
%.vgold8:V:
	8ak -r -c -o $stem.g.8 $stem.s
	cmp $stem.g.8 expected/$stem.8
	8lk -s -H7 -E _start -o $stem.g.exe $stem.g.8
	cmp $stem.g.exe expected/$stem.exe
	8lk -S -H7 -E _start -o $stem.gsym.exe $stem.g.8
	cmp $stem.gsym.exe expected/$stem.sym.exe

%.vgold5:V:
	5ak -r -c -o $stem.g.5 $stem.s
	cmp $stem.g.5 expected/$stem.5
	5lk -s -H7 -E _start -o $stem.g.exe $stem.g.5
	cmp $stem.g.exe expected/$stem.exe

# Regenerate the golden reference outputs from the kencc lineage.
# Only run this deliberately, after verifying the new outputs are correct
# (e.g. the executables still run).
golden:V: ${TESTS386:%=%.mkgold8} ${TESTSARM:%=%.mkgold5}

%.mkgold8:V:
	8ak -r -c -o expected/$stem.8 $stem.s
	8lk -s -H7 -E _start -o expected/$stem.exe expected/$stem.8
	8lk -S -H7 -E _start -o expected/$stem.sym.exe expected/$stem.8

%.mkgold5:V:
	5ak -r -c -o expected/$stem.5 $stem.s
	5lk -s -H7 -E _start -o expected/$stem.exe expected/$stem.5

clean nuke:V:
	rm -f *.[58] *.exe *.uexe

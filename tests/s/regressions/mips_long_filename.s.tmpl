// Template copied to a >=100-byte filename by mkfile before assembling
// -- see the comment there. Content is the same minimal exit(42)
// program as tests/s/exit/exit_linux_mips.s.

TEXT _start+0(SB), $0

    MOVW $42, R4    // a0 = exit code
    MOVW $4001, R2  // v0 = syscall number (exit)
    SYSCALL
    RET              // not reached

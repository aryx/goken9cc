# Minimal repros for compiler/assembler/linker bugs, most (but not all --
# see riscv64_ptr_width below) found while diffing the mips toolchain
# (vc/va/vl) against other kencc-derived repos (see scripts/diff.rc); as
# opposed to tests/c/features, which is for ported functionality rather
# than bug fixes. Each .c file documents its own bug, root cause and
# origin in a comment at the top; see also ../../../plan9front.txt for
# the running credits list (for the ones that do have an upstream origin).

# mips_aut3_align: no runtime crash to check (see the comment in the
# .c file for why) -- instead greps vc -A's own alignment trace and
# checks the "aut3" (total align of automatic) result is a multiple of
# a MIPS word (4 bytes).
#
# riscv64_ptr_width: found (not diff-derived -- a goken-original bug in
# ic/jc's own dual-width bring-up, see the comment in the .c file) while
# getting tests/c/mini2 working for riscv64 ('j'): a string-literal
# function argument reused a stale pointer-width Type object created
# before ic's ginit() had set ewidth[TIND]=8 for 'j', throwing off
# stack-argument layout for every argument after it in the same call.
#
# riscv64_sraiw: diff-derived (miller-riscv, see the comment in the .c
# file) -- SRAIW silently executed as SRLIW (logical instead of
# arithmetic shift), discarding the sign of "x >>= n" on plain (32-bit)
# signed ints. Both riscv64 regressions share riscv64_ptr_width_start.s
# as their minimal _main/exit runtime stub.
#
# float_const_oob: not diff-derived -- found via internal cross-arch
# consistency (il and vl were the only two backends with this bug; see
# the comment in the .c file). A 4-byte-past-the-end stack overread when
# writing a float (not double) global/static initializer, in il and vl's
# datblk(). riscv (both widths) reliably reproduces it; the mips build
# happens not to (same defect, but its build's adjacent stack bytes are
# coincidentally benign) -- fixed there too on the strength of the
# riscv sibling and the fix being verbatim-identical to what every other
# backend (5l/5lk/6l/7l/8l/8lk) already does. riscv32 also reuses
# riscv64_ptr_width_start.s (assembled with ia instead of ja): the stub
# is width-agnostic.
# mulzero: diff-derived (9front, see the comment in the .c file) -- "x
# *= 0;" failed to compile ("mulgen botch") on 6c, and the identical
# bug (independently) on 8c and 8ck. Checks both that it compiles at
# all and that it computes the right (zeroed) runtime result on all
# three, not just "it didn't error".
test:V: mips_aut3_align.check riscv64_ptr_width.check riscv64_sraiw.check float_const_oob.check mulzero.check

mips_aut3_align.check:V: mips_aut3_align.c
	vc -A mips_aut3_align.c >/tmp/mips_aut3_align.$pid.trace >[2=1]
	awk '/align aut3/ { if ($NF % 4 != 0) { print "misaligned: " $0; bad=1 } } END { if (bad) exit 1 }' /tmp/mips_aut3_align.$pid.trace
	rm -f /tmp/mips_aut3_align.$pid.trace

riscv64_ptr_width.check:V: riscv64_ptr_width.c riscv64_ptr_width_start.s
	jc -Driscv64 -c riscv64_ptr_width.c
	ja -Driscv64 -c riscv64_ptr_width_start.s
	jl -o riscv64_ptr_width.exe -E _main riscv64_ptr_width.j riscv64_ptr_width_start.j
	st=`{ ../../../scripts/qemu-runner riscv64 ./riscv64_ptr_width.exe; echo $status }
	if (~ $st 0)
		echo 'ok: riscv64_ptr_width.exe exit 0'
	if not {
		echo 'FAILED: riscv64_ptr_width.exe (got '$st')'
		exit failed
	}

riscv64_sraiw.check:V: riscv64_sraiw.c riscv64_ptr_width_start.s
	jc -Driscv64 -c riscv64_sraiw.c
	ja -Driscv64 -c riscv64_ptr_width_start.s
	jl -o riscv64_sraiw.exe -E _main riscv64_sraiw.j riscv64_ptr_width_start.j
	st=`{ ../../../scripts/qemu-runner riscv64 ./riscv64_sraiw.exe; echo $status }
	if (~ $st 0)
		echo 'ok: riscv64_sraiw.exe exit 0'
	if not {
		echo 'FAILED: riscv64_sraiw.exe (got '$st')'
		exit failed
	}

float_const_oob.check:V: float_const_oob.c float_const_oob_start_mips.s riscv64_ptr_width_start.s
	vc -Dmips -c float_const_oob.c
	va -Dmips -c float_const_oob_start_mips.s
	vl -o float_const_oob_mips.exe -E _main float_const_oob.v float_const_oob_start_mips.v
	ic -Driscv -c float_const_oob.c
	ia -Driscv -c riscv64_ptr_width_start.s
	il -o float_const_oob_riscv.exe -E _main float_const_oob.i riscv64_ptr_width_start.i
	jc -Driscv64 -c float_const_oob.c
	ja -Driscv64 -c riscv64_ptr_width_start.s
	jl -o float_const_oob_riscv64.exe -E _main float_const_oob.j riscv64_ptr_width_start.j
	for (a in mips riscv riscv64) {
		st=`{ ../../../scripts/qemu-runner $a ./float_const_oob_$a.exe; echo $status }
		if (~ $st 0)
			echo 'ok: float_const_oob_'$a'.exe exit 0'
		if not {
			echo 'FAILED: float_const_oob_'$a'.exe (got '$st')'
			exit failed
		}
	}

mulzero.check:V: mulzero.c mulzero_start_amd64.s mulzero_start_386.s
	6c -c mulzero.c
	6a -c mulzero_start_amd64.s
	6l -o mulzero_amd64.exe -E _main mulzero.6 mulzero_start_amd64.6
	8a -c mulzero_start_386.s
	8c -c mulzero.c
	8l -o mulzero_8c_386.exe -E _main mulzero.8 mulzero_start_386.8
	8ck -c mulzero.c
	8l -o mulzero_8ck_386.exe -E _main mulzero.8 mulzero_start_386.8
	st=`{ ../../../scripts/qemu-runner amd64 ./mulzero_amd64.exe; echo $status }
	if (~ $st 0)
		echo 'ok: mulzero_amd64.exe (6c) exit 0'
	if not {
		echo 'FAILED: mulzero_amd64.exe (6c) (got '$st')'
		exit failed
	}
	st=`{ ../../../scripts/qemu-runner 386 ./mulzero_8c_386.exe; echo $status }
	if (~ $st 0)
		echo 'ok: mulzero_8c_386.exe (8c) exit 0'
	if not {
		echo 'FAILED: mulzero_8c_386.exe (8c) (got '$st')'
		exit failed
	}
	st=`{ ../../../scripts/qemu-runner 386 ./mulzero_8ck_386.exe; echo $status }
	if (~ $st 0)
		echo 'ok: mulzero_8ck_386.exe (8ck) exit 0'
	if not {
		echo 'FAILED: mulzero_8ck_386.exe (8ck) (got '$st')'
		exit failed
	}

clean:V:
	rm -f *.v *.j *.i *.o *.6 *.8 o.out *.exe

# Cross-check the two C compiler lineages on toy inputs:
#  - the kencc lineage (8ck, from compilers/8ck), known good, the
#    original reference
#  - the principia-synced lineage (8c, from compilers/8c), kept in
#    sync with the principia books via syncweb; now the default install
#    name since it was proven byte-identical to kencc over the whole
#    principia corpus (see tests/scripts/cmp-*-corpus.sh)
# See also tests/s/variants for the assemblers and linkers.
#
# Each local .c file is the minimal repro of a mismatch found between
# the lineages (see the comment at the top of each file). The files
# from ../misc are the historical -m32 vs -m64 long->int32 triggers.
#
# expected/ holds golden reference outputs produced by the kencc lineage
# with -r (reproducible: no cwd in the object history); regenerate them
# with the 'golden' target.

CTESTS=unsigned_long manyvars not_byte float_parse label_if
CTESTSMISC=f_1_e_126 minus_one_index switch_hex float vlong_max
# arm C tests: kencc 5c vs principia 5c___ (arm lineage not swapped yet)
CTESTSARM=reg_alloc_arm float_cmp_arm

test:V: ${CTESTS:%=%.vcmp} ${CTESTSMISC:%=%.vcmpm} testarm testgolden

testarm:V: ${CTESTSARM:%=%.vcmp5} bigfunc_arm

# bigfunc_arm: a single function whose compiled text exceeds 128K (1<<17),
# to exercise the arm linker's large-procedure path. principia's 5l___
# used to diag()+errorexit() ("Procedure too large") where kencc 5l keeps
# going (ARM B/BL reach +-32MB, so the procedure links fine); both must
# now link it byte-identically. See linkers/5l/layout.c dotext(). The
# source is generated (not committed) because a >128K function is huge;
# entry is f itself so no libc/startup is needed.
bigfunc_arm:V:
	awk 'BEGIN{print "long g;"; print "long f(void){"; print "  long x=g;"; for(i=1;i<7000;i++) print "  x=x+g*"i";"; print "  return x;"; print "}"}' > bigfunc_arm.c
	5c    -r -o bigfunc_arm.5 bigfunc_arm.c
	5l    -H7 -E f -o bigfunc_arm.k.exe bigfunc_arm.5
	5l___ -H7 -E f -o bigfunc_arm.p.exe bigfunc_arm.5
	cmp bigfunc_arm.k.exe bigfunc_arm.p.exe

testgolden:V: ${CTESTS:%=%.vgold} ${CTESTSMISC:%=%.vgoldm} ${CTESTSARM:%=%.vgold5}

# arm: compare kencc 5c and principia 5c___ object files
%.vcmp5:V:
	5c    -r -o $stem.k.5 $stem.c
	5c___ -r -o $stem.p.5 $stem.c
	cmp $stem.k.5 $stem.p.5

%.vgold5:V:
	5c -r -o $stem.g.5 $stem.c
	cmp $stem.g.5 expected/$stem.5

%.mkgold5:V:
	5c -r -o expected/$stem.5 $stem.c

%.vcmp:V:
	8ck -r -o $stem.k.8 $stem.c
	8c  -r -o $stem.p.8 $stem.c
	cmp $stem.k.8 $stem.p.8

%.vcmpm:V:
	8ck -r -o $stem.k.8 ../misc/$stem.c
	8c  -r -o $stem.p.8 ../misc/$stem.c
	cmp $stem.k.8 $stem.p.8

# uses .g.* names because mk can run this in parallel with the cmp rules
%.vgold:V:
	8ck -r -o $stem.g.8 $stem.c
	cmp $stem.g.8 expected/$stem.8

%.vgoldm:V:
	8ck -r -o $stem.g.8 ../misc/$stem.c
	cmp $stem.g.8 expected/$stem.8

# Regenerate the golden reference outputs from the kencc lineage.
# Only run this deliberately, after verifying the new outputs are correct.
golden:V: ${CTESTS:%=%.mkgold} ${CTESTSMISC:%=%.mkgoldm} ${CTESTSARM:%=%.mkgold5}

%.mkgold:V:
	8ck -r -o expected/$stem.8 $stem.c

%.mkgoldm:V:
	8ck -r -o expected/$stem.8 ../misc/$stem.c

clean nuke:V:
	rm -f *.[58] *.exe bigfunc_arm.c

TOP=../../..
<$TOP/mkconfig
<$TOP/mkfiles/$objtype/mkfile

all:V: helloprintf.exe
clean:V:
	rm -f *.[5678ijv] *.exe *.a
test_one:V: all
	./helloprintf.exe | cmp /dev/stdin helloprintf.expected.txt

#config: add -DDEBUG if needed
CPP_FLAGS=-D$objtype

#config: can also add -v for verbose mode to help debug
helloprintf.exe: helloprintf.c
   $CC_ $CPP_FLAGS -c test.c
   $CC_ $CPP_FLAGS -c print_nofloat_no64.c
   $CC_ $CPP_FLAGS -c helloprintf.c
   $AS_ $CPP_FLAGS -c linux_$objtype.s
   $AR_ rc libprint.a linux_$objtype.$O_ print*.$O_ test.$O_
   $LD_ -L. -o $target -E _main helloprintf.$O_

ARCHS=386 amd64 arm arm64 mips riscv riscv64
test:V:
        for (arch in $ARCHS) {
           echo $arch
           mk clean
           mk 'objtype='$arch
           $TOP/scripts/qemu-runner $arch ./helloprintf.exe | cmp /dev/stdin helloprintf.expected.txt
        }


# macOS arm64: Darwin syscall stubs, Mach-O (-H6), mandatory ad-hoc
# signature (see docs/notes_macos.txt). Runs natively on Apple Silicon.
helloprintf_macos_arm64.exe: helloprintf.c
   7c -Darm64 -c test.c
   7c -Darm64 -c print_nofloat_no64.c
   7c -Darm64 -c helloprintf.c
   7a -Darm64 -c macos_arm64.s
   arg rc libprint.a macos_arm64.7 print*.7 test.7
   7l -H6 -L. -o $target -E _main helloprintf.7
   if(~ `{uname} Darwin) codesign -s - -f $target
   if not true

# 7c code generation regression test (see comments in regress7c.c);
# reuses the print/stub objects built by the helloprintf rule above
regress7c_macos_arm64.exe: regress7c.c helloprintf_macos_arm64.exe
   7c -Darm64 -c regress7c.c
   7l -H6 -L. -o $target -E _main regress7c.7
   if(~ `{uname} Darwin) codesign -s - -f $target
   if not true

# runs natively on Apple Silicon (no qemu needed)
test_macos_arm64:V: helloprintf_macos_arm64.exe regress7c_macos_arm64.exe
	./helloprintf_macos_arm64.exe | cmp /dev/stdin helloprintf.expected.txt
	./regress7c_macos_arm64.exe


# macOS amd64: Darwin syscall stubs (BSD syscall numbers OR'd with the
# 0x2000000 Unix class bit), Mach-O (-H6). 6l -H6 is always PIE, so 6c
# needs -z (position-independent code: no absolute $sym(SB) immediates in
# arithmetic, e.g. "(char*)buf + i") and 6l needs the RIP-relative fix in
# linkers/6l/span.c; see docs/notes_macos.txt. Runs natively on Intel Macs.
# TODO? install darling to run macos binaries from Linux
helloprintf_macos_amd64.exe: helloprintf.c
   6c -z -Damd64 -c test.c
   6c -z -Damd64 -c print_nofloat_no64.c
   6c -z -Damd64 -c helloprintf.c
   6a -Damd64 -c macos_amd64.s
   iar rc libprint.a macos_amd64.6 print*.6 test.6
   6l -s -H6 -L. -o $target -E _main helloprintf.6
   if(~ `{uname} Darwin) codesign -s - -f $target
   if not true

# 6c code generation regression test (reuses the print/stub objects
# built by the helloprintf rule above); same regress7c.c as arm64
regress7c_macos_amd64.exe: regress7c.c helloprintf_macos_amd64.exe
   6c -z -Damd64 -c regress7c.c
   6l -s -H6 -L. -o $target -E _main regress7c.6
   if(~ `{uname} Darwin) codesign -s - -f $target
   if not true

# runs natively on Intel Macs (no qemu needed)
test_macos_amd64:V: helloprintf_macos_amd64.exe regress7c_macos_amd64.exe
	./helloprintf_macos_amd64.exe | cmp /dev/stdin helloprintf.expected.txt
	./regress7c_macos_amd64.exe


# wasm regression test for compilers/ec (if/else + recursion so far --
# see docs/notes_wasm.txt and regress_wasm.c's own comment). ec has no
# printf/WASI runtime wired up yet, so unlike every recipe above this
# is verified by calling runtests() directly and checking its return
# value (scripts/wasm-call-runner.js), not by comparing captured
# stdout against an expected.txt.
regress_wasm.wasm: regress_wasm.c
   ec -o regress_wasm.e regress_wasm.c
   el -o $target regress_wasm.e

test_wasm:V: regress_wasm.wasm
	node $TOP/scripts/wasm-call-runner.js regress_wasm.wasm runtests

# useful when troubleshooting issues to just get rid of the use of ar and
# get rid of float/64 bits instructions and see if everything
# else works at least
helloprintf_nofloat_no64.exe: helloprintf.c
   $CC_ $CPP_FLAGS -c print_nofloat_no64.c
   $CC_ $CPP_FLAGS -c helloprintf.c
   $AS_ $CPP_FLAGS -c linux_$objtype.s
   #$AR_ rc libprint.a linux_$objtype.$O_ print_nofloat_no64.$O_
   $LD_ -L. -o $target -E main helloprintf.$O_ linux_$objtype.$O_ print_nofloat_no64.$O_

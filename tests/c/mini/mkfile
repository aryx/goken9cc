# can use $CC_ -S to see the assembly code
TOP=../../..
<$TOP/mkconfig
<$TOP/mkfiles/$objtype/mkfile

all:V: helloc.exe
clean:V:
        rm -f *.[5678ijv] *.exe *.a
test_one:V: all
        ./helloc.exe | cmp /dev/stdin helloc.expected.txt

#TODO? 'ar rc'? in principia we use 'ar vu'
#old: $LD_ -X to require NOSPLIT for all linked code, especially in $stem.6
#alt: ar rc libmini.a *.$O_   below
helloc.exe: helloc.c
   $CC_ -D$objtype -c $prereq
   $AS_ -D$objtype -c start_$objtype.s
   $AS_ -D$objtype -c xwrite_$objtype.s
   $AS_ -D$objtype -c xexit_$objtype.s
   $AR_ rc libmini.a start_$objtype.$O_ xwrite_$objtype.$O_ xexit_$objtype.$O_
   $LD_ -L. -o $target -E _start helloc.$O_

ARCHS=386 amd64 arm arm64 mips riscv
test:V:
        for (arch in $ARCHS) {
           echo $arch
           mk clean
           #alt: build 5.helloc 8.helloc
           mk 'objtype='$arch
           # Some arches need a differently-named qemu binary (like the
           # qemu-mips special case in tests/s/mini/mkfile): 386's is
           # qemu-i386, and riscv's ELF32 image runs under qemu-riscv32.
           if (~ $arch 386)
              qemu-i386 ./helloc.exe | cmp /dev/stdin helloc.expected.txt
           if not if (~ $arch riscv)
              qemu-riscv32 ./helloc.exe | cmp /dev/stdin helloc.expected.txt
           if not
              qemu-$arch ./helloc.exe | cmp /dev/stdin helloc.expected.txt
        }
	#alt: special if in for loop above
	echo arm__
	mk clean
	mk helloc_arm__.exe
	qemu-arm ./helloc_arm__.exe | cmp /dev/stdin helloc.expected.txt


# runs natively on Apple Silicon (no qemu needed)
test_macos:V: helloc_macos_arm64.exe
        ./helloc_macos_arm64.exe | cmp /dev/stdin helloc.expected.txt

# macOS arm64: same helloc.c but with the Darwin syscall stubs, the
# Mach-O header (-H6) and the mandatory ad-hoc code signature
# (see docs/notes_macos.txt); start_arm64.s is OS-independent so it
# is reused as-is. Runs natively on Apple Silicon.
helloc_macos_arm64.exe: helloc.c
   7c -Darm64 -c helloc.c
   7a -Darm64 -c start_arm64.s
   7a -Darm64 -c xwrite_macos_arm64.s
   7a -Darm64 -c xexit_macos_arm64.s
   ar_ rc libmini.a start_arm64.7 xwrite_macos_arm64.7 xexit_macos_arm64.7
   7l -H6 -L. -o $target -E _start helloc.7
   if(~ `{uname} Darwin) codesign -s - -f $target
   if not true

# runs natively on Intel Macs (no qemu needed)
# the cmp is not just belt-and-suspenders here: this target is what caught
# a real 6l bug (see the comment on helloc_macos_amd64.exe below) where the
# binary linked, ran, and exited 0 while writing nothing at all -- a bare
# "it ran" check would have passed.
test_macos_amd64:V: helloc_macos_amd64.exe
        ./helloc_macos_amd64.exe | cmp /dev/stdin helloc.expected.txt

# macOS amd64: same helloc.c but with the Darwin syscall stubs (BSD
# syscall numbers OR'd with the 0x2000000 Unix class bit, see
# tests/s/mini/hello_macos_amd64.s) and the Mach-O header (-H6);
# start_amd64.s is OS-independent so it is reused as-is. Runs
# natively on Intel Macs.
#
# 6c compiles "xwrite(\"str\", n)" into "MOVQ $sym(SB), R" -- the address
# of the string constant loaded as a link-time absolute immediate. That is
# fine for non-PIE ELF/PE, but 6l -H6 always sets MH_PIE, so the kernel
# slides the image at exec() and the baked-in address is wrong; write()
# then silently fails (unchecked in xwrite) and the program exits 0 having
# printed nothing. Fixed in src/cmd/6l/span.c oclass(): when HEADTYPE==6,
# "$extern(SB)" now routes through the same Zaut_r/asmand "built-in LEA"
# path already used for LEAQ and for stack-local addresses, which already
# had PIE-aware RIP-relative encoding (see asmandsz's HEADTYPE==6 case).
# See also docs/notes_macos.txt.
helloc_macos_amd64.exe: helloc.c
   6c -Damd64 -c helloc.c
   6a -Damd64 -c start_amd64.s
   6a -Damd64 -c xwrite_macos_amd64.s
   6a -Damd64 -c xexit_macos_amd64.s
   ar_ rc libmini.a start_amd64.6 xwrite_macos_amd64.6 xexit_macos_amd64.6
   6l -s -H6 -L. -o $target -E _start helloc.6
   if(~ `{uname} Darwin) codesign -s - -f $target
   if not true

#alt: 5l_ -H7 -L. -o $target -E _start helloc.5 xwrite_arm.5 xexit_arm.5 start_arm.5
# when ar_ is not working
#alt: could factorize with previous rule but would need some start_arm_.s
# symlink to start_arm.s
helloc_arm__.exe: helloc.c
   5c__ -Darm__ -c helloc.c
   5a__ -Darm__ -c xwrite_arm.s
   5a__ -Darm__ -c xexit_arm.s
   5a__ -Darm__ -c start_arm.s
   ar_ rc libmini.a start_arm.5 xwrite_arm.5 xexit_arm.5
   5l__ -H7 -L. -o $target -E _start helloc.5

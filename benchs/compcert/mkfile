# Micro-benchmarks originally from the CompCert project (see pad.txt),
# used here to compare gcc/clang -O0 vs -O3 (and, later, goken's own
# Xc/Xa/Xl pipeline once it can build this corpus too -- see TODO below).
# gcc -O0 is the fixed baseline every variant is compared against, in
# bench and (eventually) across compilers -- see bench.sh.
#
# Modeled after ./Makefile (the original CompCert GNU Makefile for this
# corpus) but using mk/rc instead of make/bash, and gcc/clang instead of
# ccomp.
#
#   mk          # just compile everything (gcc/clang, -O0 and -O3)
#   mk test     # compile + check stdout of every program against Results/
#   mk bench    # compile + timing summary, all variants vs gcc -O0
#   mk clean

GCC=gcc
CLANG=clang
# -fgnu89-inline: spectral.c's `inline double eval_A(...)` has no other
# definition in the translation unit. Under gcc/clang's default (C99/gnu11)
# inline semantics that's only valid if the compiler actually inlines
# every call; at -O0 it doesn't, so the plain -O0 build fails to link
# ("undefined reference to eval_A"). gnu89 inline semantics always keep a
# callable out-of-line copy, so both -O0 and -O3 link either way.
CFLAGS=-Wall -fgnu89-inline
LIBS=-lm

PROGS=fib integr qsort fft fftsp fftw sha1 sha3 aes almabench \
	lists binarytrees fannkuch knucleotide mandelbrot nbody \
	nsieve nsievebits spectral vmach \
	bisect chomp perlin siphash24

# gcc-O0 is the baseline (see VARIANTS in bench.sh); -O3 is each
# compiler's "fastest" in a way still directly comparable to the others
# (no -Ofast/-ffast-math, which could also break the Results/ diff on the
# floating-point-heavy benchmarks like almabench/fftw).
GCCO0BINS=${PROGS:%=%.gcc-O0}
GCCO3BINS=${PROGS:%=%.gcc-O3}
CLANGO0BINS=${PROGS:%=%.clang-O0}
CLANGO3BINS=${PROGS:%=%.clang-O3}

all:V: $GCCO0BINS $GCCO3BINS $CLANGO0BINS $CLANGO3BINS

%.gcc-O0: %.c
	$GCC $CFLAGS -O0 -o $target $stem.c $LIBS

%.gcc-O3: %.c
	$GCC $CFLAGS -O3 -o $target $stem.c $LIBS

%.clang-O0: %.c
	$CLANG $CFLAGS -O0 -o $target $stem.c $LIBS

%.clang-O3: %.c
	$CLANG $CFLAGS -O3 -o $target $stem.c $LIBS

# Each program prints to stdout and must match Results/<prog> exactly.
# Piped through /dev/stdin rather than the more common 'cmp - foo': this
# project builds and installs its own cmp/diff (utilities/compare/), and
# those open() their arguments literally instead of special-casing '-' as
# stdin, so 'cmp -s - Results/$i' silently "FAILED" every entry once
# ROOT/$objtype/bin is ahead of the system cmp on $PATH. /dev/stdin is a
# real path any cmp can open, so it works with either implementation.
test:V: all
	for(opt in gcc-O0 gcc-O3 clang-O0 clang-O3){
		echo '--' $opt '--'
		for(i in $PROGS){
			if(./$i.$opt | cmp -s /dev/stdin Results/$i)
				echo $i': passed'
			if not
				echo $i': FAILED'
		}
	}

# Timing summary, every variant vs the gcc -O0 baseline. The arithmetic
# (best-of-N, speedup ratios) is easier in bash than rc, so that part
# alone lives in bench.sh; see its header for why it uses bash's `time`
# builtin instead of an external command, and VARIANTS for the compiler
# list (extend it there, not here, once goken joins the comparison).
bench:V: all
	bash bench.sh $PROGS

clean:V:
	rm -f $GCCO0BINS $GCCO3BINS $CLANGO0BINS $CLANGO3BINS

